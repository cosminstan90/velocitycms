DATABASE_URL=postgresql://cms_user:cms_pass@localhost:5432/velocitycms
AUTH_SECRET=your-auth-secret-here
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000
REDIS_URL=redis://localhost:6379
CMS_PUBLISHER_TOKEN=your-publisher-token-here
BACKUP_PATH=/backups
ANTHROPIC_API_KEY=your-anthropic-api-key-here
BREVO_API_KEY=your-brevo-api-key-here
BREVO_FROM_EMAIL=noreply@yourdomain.com
PAGESPEED_API_KEY=your-pagespeed-api-key-here
UMAMI_WEBSITE_ID=your-umami-website-id
UMAMI_URL=http://localhost:3001
CRON_SECRET=your-cron-secret-here
INTERNAL_API_KEY=your-internal-api-key-here

# ── Production Docker overrides ───────────────────────────────────────────────
# Copy this section to .env.prod on your VPS (never commit .env.prod to git)
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_USER=cms_user
POSTGRES_DB=velocitycms
REDIS_PASSWORD=

# CORS: comma-separated origins allowed to call /api/public/* (leave empty for *)
CORS_ALLOWED_ORIGINS=https://divet.ro,https://www.divet.ro

# ── divet.ro production values ────────────────────────────────────────────────
# NEXTAUTH_URL=https://divet.ro
# DATABASE_URL=postgresql://cms_user:STRONG_PASS@postgres:5432/velocitycms
# REDIS_URL=redis://:REDIS_PASS@redis:6379
# AUTH_SECRET=   # openssl rand -base64 32
# CRON_SECRET=   # openssl rand -hex 32
# INTERNAL_API_KEY=   # openssl rand -hex 32
# CMS_PUBLISHER_TOKEN=   # openssl rand -hex 32
